{
  "name": "markdownviewer",
  "version": "1.0.0",
  "description": "A fast, lightweight Markdown viewer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "release": "electron-builder --publish always",
    "download": "gh release download --pattern *Setup*.exe --dir %USERPROFILE%/Downloads --clobber"
  },
  "keywords": [],
  "author": "AnsCodeLab",
  "license": "ISC",
  "dependencies": {
    "clean-css": "^5.3.3",
    "docx": "^9.6.1",
    "highlight.js": "^11.11.1",
    "html-minifier-terser": "^7.2.0",
    "markdown-it": "^14.1.1",
    "prettier": "^3.8.1",
    "sanitize-html": "^2.17.1",
    "terser": "^5.46.0"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.anzdev4life.markdownviewer",
    "productName": "MarkdownViewer",
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown file",
        "role": "Viewer"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown file",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AnsCodeLab",
        "repo": "MarkdownViewer",
        "releaseType": "release"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
